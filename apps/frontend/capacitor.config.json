{
  "appId": "com.svlaki.glyde",
  "appName": "Glyde",
  "webDir": "dist",
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": false
  },
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
