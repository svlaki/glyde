    "ai": "^3.3.4",
    "chrono-node": "^2.8.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.38.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
